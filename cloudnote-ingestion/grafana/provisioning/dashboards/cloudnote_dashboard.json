      "id": 1,
      "title": "Active Browser Session Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "cloudnote_active_session_state",
          "format": "time_series",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "blue",
                  "index": 0,
                  "text": "IDLE"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "CONNECTED"
                },
                "2": {
                  "color": "orange",
                  "index": 2,
                  "text": "RECOVERING"
                },
                "3": {
                  "color": "purple",
                  "index": 3,
                  "text": "DISCONNECTED"
                },
                "4": {
                  "color": "red",
                  "index": 4,
                  "text": "FAILED"
                },
                "5": {
                  "color": "yellow",
                  "index": 5,
                  "text": "CONNECTING"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
